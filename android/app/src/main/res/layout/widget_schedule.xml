<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/schedule_widget_header"
        android:layout_width="match_parent"
        android:layout_height="23dp"
        android:clickable="true"
        android:contentDescription="@string/schedule_widget_open"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/widget_app_icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/schedule_widget_title"
            android:textColor="#FFFFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/schedule_widget_count"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:background="@drawable/widget_schedule_badge"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="38dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="0 今日"
            android:textColor="#FFFFFFFF"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_row_1"
        style="@style/ScheduleWidgetRow">

        <TextView
            android:id="@+id/schedule_icon_1"
            style="@style/ScheduleWidgetIcon" />
        <TextView
            android:id="@+id/schedule_time_1"
            style="@style/ScheduleWidgetTime" />
        <TextView
            android:id="@+id/schedule_title_1"
            style="@style/ScheduleWidgetTitle" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_row_2"
        style="@style/ScheduleWidgetRow">

        <TextView
            android:id="@+id/schedule_icon_2"
            style="@style/ScheduleWidgetIcon" />
        <TextView
            android:id="@+id/schedule_time_2"
            style="@style/ScheduleWidgetTime" />
        <TextView
            android:id="@+id/schedule_title_2"
            style="@style/ScheduleWidgetTitle" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/schedule_row_3"
        style="@style/ScheduleWidgetRow">

        <TextView
            android:id="@+id/schedule_icon_3"
            style="@style/ScheduleWidgetIcon" />
        <TextView
            android:id="@+id/schedule_time_3"
            style="@style/ScheduleWidgetTime" />
        <TextView
            android:id="@+id/schedule_title_3"
            style="@style/ScheduleWidgetTitle" />
    </LinearLayout>
</LinearLayout>

